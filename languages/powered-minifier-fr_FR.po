#: admin/class-powered-minifier-admin.php:74
msgid "Powered Minifier"
msgstr "Powered Minifier"

#: admin/class-powered-minifier-admin.php:86
msgid "Settings"
msgstr "Paramètres"

#: admin/partials/powered-minifier-admin-options.php:4
msgid "Your settings have been successfully updated."
msgstr "Vos paramètres ont été mis à jour avec succès."

#: admin/partials/powered-minifier-admin-options.php:23
msgid "You have not set up your minifier options ! In order to do so, please use the below form."
msgstr "Vous n'avez pas configuré vos options de minification ! Pour ce faire, veuillez utiliser le formulaire ci-dessous."

#: admin/partials/powered-minifier-admin-options.php:28
msgid "Your plugin is properly configured ! You can change at anytime your minifier options using the below form."
msgstr "Votre plugin est correctement configuré ! Vous pouvez modifier à tout moment vos options de minification en utilisant le formulaire ci-dessous."

#: admin/partials/powered-minifier-admin-options.php:37
msgid "Minify HTML"
msgstr "Minifier le HTML"

#: admin/partials/powered-minifier-admin-options.php:45
msgid "Do you want to minify your HTML HTML source ?"
msgstr "Souhaitez-vous minifier votre source HTML ?"

#: admin/partials/powered-minifier-admin-options.php:49
msgid "Minification Level"
msgstr "Niveau de minification"

#: admin/partials/powered-minifier-admin-options.php:53
msgid "Low (higher readability)"
msgstr "Faible (meilleure lisibilité)"

#: admin/partials/powered-minifier-admin-options.php:54
msgid "Highest (no readability, smallest size)"
msgstr "Élevé (aucune lisibilité, taille minimale)"

#: admin/partials/powered-minifier-admin-options.php:76
msgid "Minify CSS"
msgstr "Minifier le CSS"

#: admin/partials/powered-minifier-admin-options.php:84
msgid "Do you want to minify the CSS code present in the HTML source ?"
msgstr "Souhaitez-vous minifier le code CSS présent dans la source HTML ?"

#: admin/partials/powered-minifier-admin-options.php:88
msgid "Minify JS"
msgstr "Minifier le JS"

#: admin/partials/powered-minifier-admin-options.php:96
msgid "Do you want to minify the JS code present in the HTML source ?"
msgstr "Souhaitez-vous minifier le code JS présent dans la source HTML ?"

#: admin/partials/powered-minifier-admin-options.php:100
msgid "Remove HTML / CSS and JS Comments"
msgstr "Supprimer les commentaires HTML/CSS/JS"

#: admin/partials/powered-minifier-admin-options.php:108
msgid "Do you want to remove the HTML / CSS and JS comments from the HTML source ?"
msgstr "Souhaitez-vous supprimer les commentaires HTML/CSS/JS de la source HTML ?"

#: admin/partials/powered-minifier-admin-options.php:112
msgid "Remove HTML / CSS and JS empty lines"
msgstr "Supprimer les lignes vides HTML/CSS/JS"

#: admin/partials/powered-minifier-admin-options.php:120
msgid "Do you want to remove the HTML / CSS and JS empty lines from the HTML source ?"
msgstr "Souhaitez-vous supprimer les lignes vides HTML/CSS/JS de la source HTML ?"

#: admin/partials/powered-minifier-admin-options.php:124
msgid "Remove XHTML closing tag from HTML5 void elements"
msgstr "Supprimer la balise fermante XHTML des éléments vides HTML5"

#: admin/partials/powered-minifier-admin-options.php:132
msgid "Do you want to remove the XHTML closing tag ? (If you are not sure leave \"ON\")"
msgstr "Souhaitez-vous supprimer la balise fermante XHTML ? (En cas de doute, laissez \"ACTIVÉ\")"

#: admin/partials/powered-minifier-admin-options.php:136
msgid "Remove relative domain from internal URLs"
msgstr "Supprimer le domaine relatif des URL internes"

#: admin/partials/powered-minifier-admin-options.php:144
msgid "Do you want to remove the relative domain from the internal URLs ? (If you are not sure leave \"OFF\")"
msgstr "Souhaitez-vous supprimer le domaine relatif des URL internes ? (En cas de doute, laissez \"DÉSACTIVÉ\")"

#: admin/partials/powered-minifier-admin-options.php:148
msgid "Remove HTTP/HTTPS from all URLs"
msgstr "Supprimer HTTP/HTTPS de toutes les URL"

#: admin/partials/powered-minifier-admin-options.php:156
msgid "Do you want to remove the HTTP & HTTPS schemes from all URLs ? (If you are not sure leave \"OFF\")"
msgstr "Souhaitez-vous supprimer les protocoles HTTP/HTTPS de toutes les URL ? (En cas de doute, laissez \"DÉSACTIVÉ\")"

#: admin/partials/powered-minifier-admin-options.php:160
msgid "Support Multi-Byte UTF-8 encoding"
msgstr "Prise en charge de l'encodage multi-octets UTF-8"

#: admin/partials/powered-minifier-admin-options.php:168
msgid "Do you want to support multi-byte encoding if you see odd encoding ? (If you are not sure leave \"OFF\")"
msgstr "Souhaitez-vous prendre en charge l'encodage multi-octets si vous constatez un encodage étrange ? (En cas de doute, laissez \"DÉSACTIVÉ\")"

#: admin/partials/powered-minifier-admin-options.php:172
msgid "Display Stats"
msgstr "Afficher les statistiques"

#: admin/partials/powered-minifier-admin-options.php:180
msgid "Do you want to display the minification stats at the bottom of the HTML source ?"
msgstr "Souhaitez-vous afficher les statistiques de minification en bas de la source HTML ?"

#: admin/partials/powered-minifier-admin-options.php:184
msgid "Debug Comments"
msgstr "Commentaires de débogage"

#: admin/partials/powered-minifier-admin-options.php:192
msgid "Do you want to display the debug html comments at the header and footer of the HTML source ?"
msgstr "Souhaitez-vous afficher les commentaires HTML de débogage dans l'en-tête et le pied de page de la source HTML ?"

#: admin/partials/powered-minifier-admin-options.php:196
msgid "Console Load Time"
msgstr "Temps de chargement console"

#: admin/partials/powered-minifier-admin-options.php:204
msgid "Do you want to display the page loading time into your browser console ? (If you are not sure leave \"OFF\")"
msgstr "Souhaitez-vous afficher le temps de chargement de la page dans la console de votre navigateur ? (En cas de doute, laissez \"DÉSACTIVÉ\")"

#: admin/partials/powered-minifier-admin-options.php:208
msgid "Update Settings"
msgstr "Mettre à jour les paramètres"

#. Plugin URI of the plugin/theme
msgid "https://wordpress.org/plugins/powered-minifier/"
msgstr "https://wordpress.org/plugins/powered-minifier/"

#. Description of the plugin/theme
msgid "Powered Minifier allow you to reduce your page load and increase your performance by minifying your HTML source along with all the CSS and JS code present in your markup."
msgstr "Powered Minifier vous permet de réduire le temps de chargement de vos pages et d'augmenter vos performances en minifiant votre source HTML ainsi que tout le code CSS et JS présent dans votre balisage."

#. Author of the plugin/theme
msgid "NeosLab"
msgstr "NeosLab"

#. Author URI of the plugin/theme
msgid "https://neoslab.com"
msgstr "https://neoslab.com"